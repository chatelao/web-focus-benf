start ::= (request | dm_command | join_command | set_command | define_file | compound_layout_block)* EOF
request ::= ( TABLE FILE qualified_name ) (verb_command | by_command | across_command | where_command | when_command | show_command | heading_command | footing_command | on_command | compute_command | recap_command | summarize_command | dm_command | STRING)* end_command
compound_layout_block ::= COMPOUND LAYOUT output_command (( (( NAME | ( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) | IS | CONTAINS | OMITS | LIKE | TOTAL | MISSING | INCLUDES | EXCLUDES | EXCEEDS | ALL | LESS | THAN | MORE_KW | GREATER | OFF | ON | RECAP | INDENT | ACROSS_TOTAL | COMPOUND | LAYOUT | SECTION | PAGELAYOUT | COMPONENT | MERGE | ORIENTATION | LANDSCAPE | PORTRAIT | TYPE | POSITION | DIMENSION | STYLE | ENDSTYLE | MATCHING | MATCHED | UPDATE | INSERT | INTO | HEADING | FOOTING | SUBHEAD | SUBFOOT | FORMAT | TIMES | WHILE | UNTIL | FOR | STEP | TOP | BOTTOM | RANKED | NOPRINT | AS | IN | HIERARCHY | WHEN | SHOW | UP | DOWN | OPEN | CLOSE | PAGE_BREAK | DRILLTHROUGH | COLUMN | LINE | ITEM | COLOR ) | TYPE) EQ layout_value (COMMA ( (( NAME | ( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) | IS | CONTAINS | OMITS | LIKE | TOTAL | MISSING | INCLUDES | EXCLUDES | EXCEEDS | ALL | LESS | THAN | MORE_KW | GREATER | OFF | ON | RECAP | INDENT | ACROSS_TOTAL | COMPOUND | LAYOUT | SECTION | PAGELAYOUT | COMPONENT | MERGE | ORIENTATION | LANDSCAPE | PORTRAIT | TYPE | POSITION | DIMENSION | STYLE | ENDSTYLE | MATCHING | MATCHED | UPDATE | INSERT | INTO | HEADING | FOOTING | SUBHEAD | SUBFOOT | FORMAT | TIMES | WHILE | UNTIL | FOR | STEP | TOP | BOTTOM | RANKED | NOPRINT | AS | IN | HIERARCHY | WHEN | SHOW | UP | DOWN | OPEN | CLOSE | PAGE_BREAK | DRILLTHROUGH | COLUMN | LINE | ITEM | COLOR ) | TYPE) EQ layout_value ))* (COMMA? DOLLAR)? ))* end_command (request | dm_command | join_command | set_command | define_file)* COMPOUND END
layout_value ::= qualified_name ('(' layout_value (layout_value | COMMA)* ')')? | NUMBER | ( NUMBER DOT NUMBER ) | '(' layout_value (layout_value | COMMA)* ')' | STRING | ON | OFF | LANDSCAPE | PORTRAIT | REPORT
define_file ::= DEFINE FILE qualified_name (define_assignment)* end_command
define_assignment ::= qualified_name (SLASH format_name)? EQ dm_expression SEMI?
compute_command ::= AND? COMPUTE qualified_name (SLASH format_name)? EQ dm_expression as_phrase? SEMI?
recap_command ::= RECAP recap_assignment+
recap_assignment ::= qualified_name ('(' dm_expression ')')? (SLASH format_name)? EQ dm_expression (SEMI? recap_option)* SEMI?
recap_option ::= as_phrase | INDENT NUMBER | NOPRINT
format_name ::= NAME (DOT NUMBER)? (NAME | NUMBER)*
join_command ::= JOIN (CLEAR asterisk | (LEFT? OUTER)? qualified_name IN qualified_name TO ALL? qualified_name IN qualified_name (AS NAME)?) SEMI?
set_command ::= SET hyphenated_name (EQ? set_value)? SEMI?
set_value ::= hyphenated_name | STRING
hyphenated_name ::= (( NAME | ( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) | IS | CONTAINS | OMITS | LIKE | TOTAL | MISSING | INCLUDES | EXCLUDES | EXCEEDS | ALL | LESS | THAN | MORE_KW | GREATER | OFF | ON | RECAP | INDENT | ACROSS_TOTAL | COMPOUND | LAYOUT | SECTION | PAGELAYOUT | COMPONENT | MERGE | ORIENTATION | LANDSCAPE | PORTRAIT | TYPE | POSITION | DIMENSION | STYLE | ENDSTYLE | MATCHING | MATCHED | UPDATE | INSERT | INTO | HEADING | FOOTING | SUBHEAD | SUBFOOT | FORMAT | TIMES | WHILE | UNTIL | FOR | STEP | TOP | BOTTOM | RANKED | NOPRINT | AS | IN | HIERARCHY | WHEN | SHOW | UP | DOWN | OPEN | CLOSE | PAGE_BREAK | DRILLTHROUGH | COLUMN | LINE | ITEM | COLOR ) | NUMBER | AMPER_VAR) (dm_token | SUB_OP (( NAME | ( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) | IS | CONTAINS | OMITS | LIKE | TOTAL | MISSING | INCLUDES | EXCLUDES | EXCEEDS | ALL | LESS | THAN | MORE_KW | GREATER | OFF | ON | RECAP | INDENT | ACROSS_TOTAL | COMPOUND | LAYOUT | SECTION | PAGELAYOUT | COMPONENT | MERGE | ORIENTATION | LANDSCAPE | PORTRAIT | TYPE | POSITION | DIMENSION | STYLE | ENDSTYLE | MATCHING | MATCHED | UPDATE | INSERT | INTO | HEADING | FOOTING | SUBHEAD | SUBFOOT | FORMAT | TIMES | WHILE | UNTIL | FOR | STEP | TOP | BOTTOM | RANKED | NOPRINT | AS | IN | HIERARCHY | WHEN | SHOW | UP | DOWN | OPEN | CLOSE | PAGE_BREAK | DRILLTHROUGH | COLUMN | LINE | ITEM | COLOR ) | NUMBER | AMPER_VAR))*
dm_token ::= LABEL_DM | SET_DM | GOTO_DM | REPEAT_DM | IF_DM | TYPE_DM | INCLUDE_DM | RUN_DM | EXIT_DM
dm_command ::= dm_set | dm_goto | dm_label | dm_if | dm_type | dm_include | dm_run | dm_exit | dm_repeat | dm_htmlform
dm_set ::= SET_DM AMPER_VAR EQ dm_expression SEMI?
dm_goto ::= GOTO_DM NAME SEMI?
dm_repeat ::= REPEAT_DM NAME (WHILE dm_logical_expression | UNTIL dm_logical_expression | ( NUMBER | ( NUMBER DOT NUMBER ) | qualified_name '(' (dm_expression (COMMA dm_expression)*)? ')' | qualified_name | AMPER_VAR | STRING | '(' dm_expression ')' ) TIMES | FOR AMPER_VAR FROM ( NUMBER | ( NUMBER DOT NUMBER ) | qualified_name '(' (dm_expression (COMMA dm_expression)*)? ')' | qualified_name | AMPER_VAR | STRING | '(' dm_expression ')' ) TO ( NUMBER | ( NUMBER DOT NUMBER ) | qualified_name '(' (dm_expression (COMMA dm_expression)*)? ')' | qualified_name | AMPER_VAR | STRING | '(' dm_expression ')' ) (STEP ( NUMBER | ( NUMBER DOT NUMBER ) | qualified_name '(' (dm_expression (COMMA dm_expression)*)? ')' | qualified_name | AMPER_VAR | STRING | '(' dm_expression ')' ))?) SEMI?
dm_label ::= LABEL_DM
dm_if ::= IF_DM dm_logical_expression (THEN GOTO? | GOTO) NAME (ELSE GOTO NAME)? SEMI?
dm_type ::= TYPE_DM (( NUMBER | ( NUMBER DOT NUMBER ) | qualified_name '(' (dm_expression (COMMA dm_expression)*)? ')' | qualified_name | AMPER_VAR | STRING | '(' dm_expression ')' ))* SEMI?
dm_include ::= INCLUDE_DM qualified_name SEMI?
dm_run ::= RUN_DM SEMI?
dm_exit ::= EXIT_DM SEMI?
dm_htmlform ::= HTMLFORM_BLOCK | HTMLFORM_DM qualified_name SEMI?
dm_expression ::= dm_if_expression
dm_if_expression ::= IF dm_logical_expression THEN dm_expression ELSE dm_expression | dm_logical_expression
dm_logical_expression ::= '(' dm_logical_expression ')' | dm_relational_expression | NOT dm_logical_expression | dm_logical_expression AND dm_logical_expression | dm_logical_expression OR dm_logical_expression
dm_relational_expression ::= ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ) (IS | EQ | NE | ( IS_NOT | IS NOT | IS SUB_OP NOT ))? MISSING | ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ) (FROM | ( IS_FROM | IS FROM | IS SUB_OP FROM ) | ( NOT_FROM | NOT FROM | NOT SUB_OP FROM )) ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ) TO ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ) | ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ) IN (FILE qualified_name | '(' ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ) (COMMA ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ))* ')') | ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ) (INCLUDES | EXCLUDES) ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ) (AND ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ))* | ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ) dm_relational_op (( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ) (OR ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* ))*) | ( ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ) (CONCAT ( ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ) ((ADD_OP | SUB_OP) ( dm_unary_expression ((MUL | SLASH) dm_unary_expression)* ))* ))* )
dm_relational_op ::= EQ | NE | LE | GE | LT | GT | CONTAINS | OMITS | LIKE | EXCEEDS | IS | ( IS_NOT | IS NOT | IS SUB_OP NOT ) | ( IS_LESS_THAN | IS LESS THAN | IS SUB_OP LESS THAN ) | ( IS_MORE_THAN | IS MORE_KW THAN | IS SUB_OP MORE_KW THAN ) | ( IS_GREATER_THAN | IS GREATER THAN | IS SUB_OP GREATER THAN ) | NOT LIKE | NOT SUB_OP LIKE
dm_unary_expression ::= (ADD_OP | SUB_OP) dm_unary_expression | ( NUMBER | ( NUMBER DOT NUMBER ) | qualified_name '(' (dm_expression (COMMA dm_expression)*)? ')' | qualified_name | AMPER_VAR | STRING | '(' dm_expression ')' )
verb_command ::= verb (field_list | asterisk)
verb ::= PRINT | SUM | LIST | COUNT | WRITE | ADD
field_list ::= THE? field_or_prefixed (field_separator? field_or_prefixed)*
field_separator ::= COMMA | AND THE | AND | THE
field_or_prefixed ::= (( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) DOT)* field
field ::= qualified_name (SLASH format_name)? as_phrase?
as_phrase ::= AS STRING
asterisk ::= '*'
by_command ::= RANKED? BY sort_options? field HIERARCHY? summarize_command? NOPRINT?
across_command ::= ACROSS sort_options? field (ACROSS_TOTAL as_phrase?)? NOPRINT?
when_command ::= WHEN dm_logical_expression SEMI?
show_command ::= SHOW (UP | DOWN) ( NUMBER | ( NUMBER DOT NUMBER ) | qualified_name '(' (dm_expression (COMMA dm_expression)*)? ')' | qualified_name | AMPER_VAR | STRING | '(' dm_expression ')' ) TO (UP | DOWN) ( NUMBER | ( NUMBER DOT NUMBER ) | qualified_name '(' (dm_expression (COMMA dm_expression)*)? ')' | qualified_name | AMPER_VAR | STRING | '(' dm_expression ')' )
sort_options ::= (HIGHEST | LOWEST | TOP | BOTTOM) NUMBER? | NUMBER
where_command ::= WHERE TOTAL? dm_logical_expression SEMI?
heading_command ::= HEADING CENTER? STRING+
footing_command ::= FOOTING CENTER? STRING+
on_command ::= ON TABLE on_table_options | ON qualified_name on_field_options
on_table_options ::= (SUBHEAD | SUBFOOT) CENTER? STRING+ | COLUMN_TOTAL_KW | ROW_TOTAL_KW | ACROSS_TOTAL (SLASH format_name)? as_phrase? qualified_name? | output_command | summarize_command | recap_command | merge_command | set_command | SET STYLE asterisk (( (( NAME | ( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) | IS | CONTAINS | OMITS | LIKE | TOTAL | MISSING | INCLUDES | EXCLUDES | EXCEEDS | ALL | LESS | THAN | MORE_KW | GREATER | OFF | ON | RECAP | INDENT | ACROSS_TOTAL | COMPOUND | LAYOUT | SECTION | PAGELAYOUT | COMPONENT | MERGE | ORIENTATION | LANDSCAPE | PORTRAIT | TYPE | POSITION | DIMENSION | STYLE | ENDSTYLE | MATCHING | MATCHED | UPDATE | INSERT | INTO | HEADING | FOOTING | SUBHEAD | SUBFOOT | FORMAT | TIMES | WHILE | UNTIL | FOR | STEP | TOP | BOTTOM | RANKED | NOPRINT | AS | IN | HIERARCHY | WHEN | SHOW | UP | DOWN | OPEN | CLOSE | PAGE_BREAK | DRILLTHROUGH | COLUMN | LINE | ITEM | COLOR ) | TYPE) EQ layout_value (COMMA ( (( NAME | ( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) | IS | CONTAINS | OMITS | LIKE | TOTAL | MISSING | INCLUDES | EXCLUDES | EXCEEDS | ALL | LESS | THAN | MORE_KW | GREATER | OFF | ON | RECAP | INDENT | ACROSS_TOTAL | COMPOUND | LAYOUT | SECTION | PAGELAYOUT | COMPONENT | MERGE | ORIENTATION | LANDSCAPE | PORTRAIT | TYPE | POSITION | DIMENSION | STYLE | ENDSTYLE | MATCHING | MATCHED | UPDATE | INSERT | INTO | HEADING | FOOTING | SUBHEAD | SUBFOOT | FORMAT | TIMES | WHILE | UNTIL | FOR | STEP | TOP | BOTTOM | RANKED | NOPRINT | AS | IN | HIERARCHY | WHEN | SHOW | UP | DOWN | OPEN | CLOSE | PAGE_BREAK | DRILLTHROUGH | COLUMN | LINE | ITEM | COLOR ) | TYPE) EQ layout_value ))* (COMMA? DOLLAR)? ))* ENDSTYLE?
on_field_options ::= (SUBHEAD | SUBFOOT) CENTER? STRING+ | summarize_command | recap_command | PAGE_BREAK
summarize_command ::= (SUBTOTAL | SUB_TOTAL | SUMMARIZE | RECOMPUTE) (summarize_options? (field as_phrase? | as_phrase) | summarize_options)?
summarize_options ::= ROLL_DOT (( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) DOT)* | (( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) DOT)+
output_command ::= (HOLD | PCHOLD | SAVE | SAVB) (AS qualified_name)? (FORMAT (NAME | verb))? (OPEN | CLOSE)?
merge_command ::= MERGE INTO FILE qualified_name matching_clause when_matched_clause? when_not_matched_clause?
matching_clause ::= MATCHING qualified_name EQ qualified_name (AND qualified_name EQ qualified_name)* SEMI?
when_matched_clause ::= WHEN MATCHED UPDATE (qualified_name EQ dm_expression SEMI?)+
when_not_matched_clause ::= WHEN NOT MATCHED INSERT (qualified_name EQ dm_expression SEMI?)+
end_command ::= END
qualified_name ::= ( NAME | ( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) | IS | CONTAINS | OMITS | LIKE | TOTAL | MISSING | INCLUDES | EXCLUDES | EXCEEDS | ALL | LESS | THAN | MORE_KW | GREATER | OFF | ON | RECAP | INDENT | ACROSS_TOTAL | COMPOUND | LAYOUT | SECTION | PAGELAYOUT | COMPONENT | MERGE | ORIENTATION | LANDSCAPE | PORTRAIT | TYPE | POSITION | DIMENSION | STYLE | ENDSTYLE | MATCHING | MATCHED | UPDATE | INSERT | INTO | HEADING | FOOTING | SUBHEAD | SUBFOOT | FORMAT | TIMES | WHILE | UNTIL | FOR | STEP | TOP | BOTTOM | RANKED | NOPRINT | AS | IN | HIERARCHY | WHEN | SHOW | UP | DOWN | OPEN | CLOSE | PAGE_BREAK | DRILLTHROUGH | COLUMN | LINE | ITEM | COLOR ) (DOT ( NAME | ( AVE | MIN | MAX | CNT | FST | LST | ASQ | MDN | MDE | PCT | RPCT | RNK | DST | TOT | SUM | CT ) | IS | CONTAINS | OMITS | LIKE | TOTAL | MISSING | INCLUDES | EXCLUDES | EXCEEDS | ALL | LESS | THAN | MORE_KW | GREATER | OFF | ON | RECAP | INDENT | ACROSS_TOTAL | COMPOUND | LAYOUT | SECTION | PAGELAYOUT | COMPONENT | MERGE | ORIENTATION | LANDSCAPE | PORTRAIT | TYPE | POSITION | DIMENSION | STYLE | ENDSTYLE | MATCHING | MATCHED | UPDATE | INSERT | INTO | HEADING | FOOTING | SUBHEAD | SUBFOOT | FORMAT | TIMES | WHILE | UNTIL | FOR | STEP | TOP | BOTTOM | RANKED | NOPRINT | AS | IN | HIERARCHY | WHEN | SHOW | UP | DOWN | OPEN | CLOSE | PAGE_BREAK | DRILLTHROUGH | COLUMN | LINE | ITEM | COLOR ))*
