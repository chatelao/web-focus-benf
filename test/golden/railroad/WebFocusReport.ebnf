GOTO_DM ::= '-' 'GOTO'
REPEAT_DM ::= '-' 'REPEAT'
IF_DM ::= '-' 'IF'
TYPE_DM ::= '-' 'TYPE'
INCLUDE_DM ::= '-' 'INCLUDE'
HTMLFORM_DM ::= '-' 'HTMLFORM'
HTMLFORM_BLOCK ::= '-' 'HTMLFORM' [ \t]+ 'BEGIN' .* '-' 'HTMLFORM' [ \t]+ 'END'
