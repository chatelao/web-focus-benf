DOLLAR ::= '$'
NUMBER ::= [0-9]+
STRING ::= '''' ANY_CHAR_EXCEPT_QUOTE* '''' | '"' ANY_CHAR_EXCEPT_DOUBLE_QUOTE* '"'
AMPER_VAR ::= ('&&' | '&') [a-zA-Z_] [a-zA-Z0-9_]*
NAME ::= [a-zA-Z_] [a-zA-Z0-9_]*
WS ::= [ \t\r\n]+
ANY_CHAR_EXCEPT_NL ::= 'ANY_CHAR_EXCEPT_NL'
ANY_CHAR_EXCEPT_QUOTE ::= 'ANY_CHAR_EXCEPT_QUOTE'
ANY_CHAR_EXCEPT_DOUBLE_QUOTE ::= 'ANY_CHAR_EXCEPT_DOUBLE_QUOTE'
