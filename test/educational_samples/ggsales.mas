  FIELDNAME=CATEGORY,     ALIAS=CAT,    FORMAT=A15,             $
  FIELDNAME=PRODUCT,      ALIAS=PROD,   FORMAT=A20,             $
  FIELDNAME=UNITS,        ALIAS=UNIT,   FORMAT=I08,             $
  FIELDNAME=DOLLARS,      ALIAS=DOL,    FORMAT=D12.2,           $
  FIELDNAME=BUDUNITS,     ALIAS=BUNIT,  FORMAT=I08,             $
  FIELDNAME=BUDDOLLARS,   ALIAS=BDOL,   FORMAT=D12.2,           $
