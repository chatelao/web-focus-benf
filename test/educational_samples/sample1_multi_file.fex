JOIN PIN IN EMPDATA TO ALL PIN IN TRAINING AS J1
DEFINE FILE EMPDATA
YEAR/YY=COURSESTART;
END

TABLE FILE EMPDATA
HEADING CENTER
"Education Cost vs. Salary"
SUM EXPENSES AS 'Education Cost' SALARY AS 'Current Salary'
AND COMPUTE PERCENT/D8.2=EXPENSES/SALARY * 100; AS 'Percent'
BY DIV
BY DEPT
WHERE YEAR EQ 1991
ON TABLE SUMMARIZE
ON TABLE SET STYLE *
TYPE=HEADING, STYLE=BOLD, COLOR=BLUE,$
TYPE=REPORT, FONT=TIMES, SIZE=8,$
TYPE=REPORT, GRID=OFF,$
ENDSTYLE
END
