-SET &REPORT_TYPE = 'SALES';
-IF &REPORT_TYPE EQ 'COGS' GOTO COGS_RPT;

-SALES_RPT
TABLE FILE GGSALES
SUM DOLLARS UNITS
BY REGION BY CATEGORY
HEADING
"Sales Report for &REPORT_TYPE"
END
-GOTO END_REPORT

-COGS_RPT
TABLE FILE GGSALES
SUM COGS
BY REGION BY CATEGORY
HEADING
"COGS Report"
END

-END_REPORT
-RUN
