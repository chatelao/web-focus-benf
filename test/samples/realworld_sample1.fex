JOIN PIN IN EMPDATA TO PIN IN TRAINING AS J1
DEFINE FILE EMPDATA
  YEAR/YY = COURSESTART;
END

TABLE FILE EMPDATA
HEADING CENTER
"Education Cost vs. Salary"
SUM EXPENSES AS 'Education,Cost' SALARY AS 'Current,Salary'
COMPUTE PERCENT/D8.2 = EXPENSES / SALARY * 100;
BY DIV
BY DEPT
WHERE YEAR EQ 1991
ON TABLE SUMMARIZE
END
